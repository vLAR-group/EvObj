ninja_required_version = 1.3
cxx = c++
nvcc = /media/SSD/zihui/simon/cuda11.3/bin/nvcc

cflags = -pthread -B /home/zihui/miniconda3/envs/SimonGrabS/compiler_compat -Wl,--sysroot=/ -Wno-unused-result -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /home/zihui/miniconda3/envs/SimonGrabS/include -fPIC -O2 -isystem /home/zihui/miniconda3/envs/SimonGrabS/include -I/media/SSD/zihui/simon/cuda11.3/include -I/media/SSD/zihui/simon/cuda11.3/include -fPIC -I/home/zihui/miniconda3/envs/SimonGrabS/lib/python3.9/site-packages/torch/include -I/home/zihui/miniconda3/envs/SimonGrabS/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/home/zihui/miniconda3/envs/SimonGrabS/lib/python3.9/site-packages/torch/include/TH -I/home/zihui/miniconda3/envs/SimonGrabS/lib/python3.9/site-packages/torch/include/THC -I/media/SSD/zihui/simon/cuda11.3/include -I/home/zihui/miniconda3/envs/SimonGrabS/include/python3.9 -c
post_cflags = -g -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=pointnet2_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++14
cuda_cflags = -I/home/zihui/miniconda3/envs/SimonGrabS/lib/python3.9/site-packages/torch/include -I/home/zihui/miniconda3/envs/SimonGrabS/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/home/zihui/miniconda3/envs/SimonGrabS/lib/python3.9/site-packages/torch/include/TH -I/home/zihui/miniconda3/envs/SimonGrabS/lib/python3.9/site-packages/torch/include/THC -I/media/SSD/zihui/simon/cuda11.3/include -I/home/zihui/miniconda3/envs/SimonGrabS/include/python3.9 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O2 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=pointnet2_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -std=c++14
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags



build /media/SSD/zihui/simon/EvObj/pointnet2/build/temp.linux-x86_64-cpython-39/src/ball_query.o: compile /media/SSD/zihui/simon/EvObj/pointnet2/src/ball_query.cpp
build /media/SSD/zihui/simon/EvObj/pointnet2/build/temp.linux-x86_64-cpython-39/src/ball_query_gpu.o: cuda_compile /media/SSD/zihui/simon/EvObj/pointnet2/src/ball_query_gpu.cu
build /media/SSD/zihui/simon/EvObj/pointnet2/build/temp.linux-x86_64-cpython-39/src/group_points.o: compile /media/SSD/zihui/simon/EvObj/pointnet2/src/group_points.cpp
build /media/SSD/zihui/simon/EvObj/pointnet2/build/temp.linux-x86_64-cpython-39/src/group_points_gpu.o: cuda_compile /media/SSD/zihui/simon/EvObj/pointnet2/src/group_points_gpu.cu
build /media/SSD/zihui/simon/EvObj/pointnet2/build/temp.linux-x86_64-cpython-39/src/interpolate.o: compile /media/SSD/zihui/simon/EvObj/pointnet2/src/interpolate.cpp
build /media/SSD/zihui/simon/EvObj/pointnet2/build/temp.linux-x86_64-cpython-39/src/interpolate_gpu.o: cuda_compile /media/SSD/zihui/simon/EvObj/pointnet2/src/interpolate_gpu.cu
build /media/SSD/zihui/simon/EvObj/pointnet2/build/temp.linux-x86_64-cpython-39/src/pointnet2_api.o: compile /media/SSD/zihui/simon/EvObj/pointnet2/src/pointnet2_api.cpp
build /media/SSD/zihui/simon/EvObj/pointnet2/build/temp.linux-x86_64-cpython-39/src/sampling.o: compile /media/SSD/zihui/simon/EvObj/pointnet2/src/sampling.cpp
build /media/SSD/zihui/simon/EvObj/pointnet2/build/temp.linux-x86_64-cpython-39/src/sampling_gpu.o: cuda_compile /media/SSD/zihui/simon/EvObj/pointnet2/src/sampling_gpu.cu





